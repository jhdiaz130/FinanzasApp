<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER AZUL -->
        <!-- HEADER AZUL OSCURO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1565C0"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Presupuesto de Comida"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TARJETA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Límite Mensual: $400,000"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:progress="95"
                    android:max="100"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$380,000 / $400,000"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¡Cuidado! Cerca de tu límite"
                    android:background="@drawable/card_red"
                    android:textColor="#FFFFFF"
                    android:padding="10dp"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Editar Presupuesto"
                    android:textColor="#2196F3"
                    android:textStyle="bold"
                    android:layout_gravity="center"/>
            </LinearLayout>

            <!-- GRAFICA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distribución de Gastos"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"/>
            </LinearLayout>

            <!-- FILTROS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filtro de Fechas"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Este Mes"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:textAllCaps="false"
                        android:includeFontPadding="false"
                        android:padding="0dp"
                        android:textColor="#000000"
                        android:background="@drawable/button_filter"
                        app:backgroundTint="@null"/>

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Esta Semana"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:textAllCaps="false"
                        android:includeFontPadding="false"
                        android:padding="0dp"
                        android:layout_marginStart="8dp"
                        android:textColor="#000000"
                        android:background="@drawable/button_filter"
                        app:backgroundTint="@null"/>

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Rango"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:textAllCaps="false"
                        android:includeFontPadding="false"
                        android:padding="0dp"
                        android:layout_marginStart="8dp"
                        android:textColor="#000000"
                        android:background="@drawable/button_filter"
                        app:backgroundTint="@null"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>